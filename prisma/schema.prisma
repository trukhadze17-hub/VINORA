
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model VehicleReport {
  id          String   @id @default(cuid())
  vin         String
  result      String
  createdAt   DateTime @default(now())
}
